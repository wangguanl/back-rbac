              "schema": {
                "type": "object",
                "properties": {
                  "roleIds": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    },
                    "description": "角色ID列表"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "分配成功"
          }
        }
      }
    },
    "/users/{id}/password": {
      "put": {
        "summary": "重置用户密码",
